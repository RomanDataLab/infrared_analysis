# Cesium Ion token — get a free token at https://cesium.com/ion/tokens
VITE_CESIUM_TOKEN=your_cesium_ion_access_token_here

# Infrared City API key — https://infrared.city
INFRARED_API_KEY=your_infrared_api_key_here

# SSL certificates (Python analysis pipeline only — not needed for the web frontend)
# SSL_CERT_FILE=/path/to/cacert.pem
# REQUESTS_CA_BUNDLE=/path/to/cacert.pem
